# Pixel Heart OS - Docker Environment
# Copy to .env and configure

# LLM Provider - Choose: "anthropic", "stepfun", or "mock"
# For immediate testing without API key, use "mock"
LLM_PROVIDER=mock
USE_MOCK_LLM=True

# Anthropic (if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# StepFun (if LLM_PROVIDER=stepfun) ⭐ Recommended for you
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_BASE_URL=https://api.stepfun.com
STEPFUN_MODEL=step-1-8k

# LLM settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
