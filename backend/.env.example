# Pixel Heart OS - Backend Configuration
# Copy this file to .env and fill in the values

# LLM Provider Configuration
# Options: "anthropic", "stepfun", "mock"
LLM_PROVIDER=anthropic
USE_MOCK_LLM=False  # Set to True for testing without API key

# Anthropic API (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# StepFun API (if LLM_PROVIDER=stepfun)
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_BASE_URL=https://api.stepfun.com
STEPFUN_MODEL=step-1-8k  # or step-1-32k, step-2-16k etc

# LLM Common Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000

# Database URLs
DATABASE_URL=sqlite+aiosqlite:///./pixel_heart.db
CHROMA_DB_PATH=./chroma_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
