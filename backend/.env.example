# Environment variables for Pixel Heart OS backend
# Copy this file to .env and fill in the actual values

# Anthropic API Key for LLM service (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database URL (SQLite by default, can be changed to PostgreSQL, etc.)
DATABASE_URL=sqlite+aiosqlite:///./data/pixel_heart_os.db

# Debug mode (True/False)
DEBUG=True

# Use mock LLM for testing without API key (True/False)
USE_MOCK_LLM=False

# ChromaDB persistence path
CHROMA_DB_PATH=./chroma_db

# Data directory for storing character souls, identities, voice configs, etc.
DATA_DIR=./data

# Secret key for session security (change in production!)
SECRET_KEY=a-very-secret-key-change-in-production

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000